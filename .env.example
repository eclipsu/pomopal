# Local dev only. On pomopal.lol / www.pomopal.lol the app uses same-origin /api automatically.
# Local dev: leave unset — the app uses http://localhost:3000/api (Next proxy → :8000).
# Do not point the browser at :8000 directly or auth cookies will not attach.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Presence WebSocket (required in production). Must be wss:// when the site is HTTPS.
# Example: NEXT_PUBLIC_SOCKET_URL=https://api.pomopal.lol
# NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=
NEXT_PUBLIC_APPWRITE_USERS_META_ID=
NEXT_PUBLIC_APPWRITE_SETTINGS_COLLECTION_ID=
NEXT_PUBLIC_APPWRITE_BUCKET=